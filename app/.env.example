# Copy to app/.env.local and fill in (values: Supabase dashboard → Project Settings).
# EXPO_PUBLIC_* values are baked into the client bundle (public-safe; RLS protects data).
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>
# Spotify Web API — public client id only (the secret lives in Supabase secrets).
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=<spotify-app-client-id>

# CLI-only secrets — never committed, never EXPO_PUBLIC_.
SUPABASE_ACCESS_TOKEN=<personal-access-token>
SUPABASE_DB_PASSWORD=<database-password>
