{
  "expo": {
    "name": "For The Record MC",
    "slug": "music-club-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fortherecordmc",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.jordanreticker.fortherecordmc",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "runtimeVersion": "731a25bc2842ae8d6396a3315e7eda90e66b4698"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080808",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": "f655d5b46e143ead2ffdb31252569a1516f16767"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080808",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#080808"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/music-club-app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2a496ca-7281-4220-b545-9b2d27378111"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/c2a496ca-7281-4220-b545-9b2d27378111"
    }
  }
}
